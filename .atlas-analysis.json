  ],
  "publicApiSurface": [
    "GET /api/series - List all series",
    "POST /api/series - Create a new series",
    "GET /api/series/{showId} - Get series details",
    "PUT /api/series/{showId} - Update series",
    "DELETE /api/series/{showId} - Delete series",
    "GET /api/series/{showId}/seasons - List seasons",
    "POST /api/series/{showId}/seasons - Create season",
    "GET /api/series/{showId}/seasons/{seasonId} - Get season details",
    "PUT /api/series/{showId}/seasons/{seasonId} - Update season",
    "DELETE /api/series/{showId}/seasons/{seasonId} - Delete season",
    "GET /api/series/{showId}/seasons/{seasonId}/chapters - List episodes",
    "POST /api/series/{showId}/seasons/{seasonId}/chapters - Create episode",
    "GET /api/series/{showId}/seasons/{seasonId}/chapters/{chapterId} - Get episode details",
    "PUT /api/series/{showId}/seasons/{seasonId}/chapters/{chapterId} - Update episode",
    "DELETE /api/series/{showId}/seasons/{seasonId}/chapters/{chapterId} - Delete episode",
    "GET /api/media/upload - Upload media content"
  ]
